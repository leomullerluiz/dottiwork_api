RewriteEngine On

# Preserve Authorization header for PHP/FastCGI environments.
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Block direct access to implementation directories.
RewriteRule ^(config|core|controller|model|service|tests|vendor|migrations|templates)/ - [F,L]

# Route everything else to the API entrypoint.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
