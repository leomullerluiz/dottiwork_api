APP_ENV=production
APP_SECRET=
APP_ENCRYPTION_KEY=

FRONTEND_URL=https://dottiwork.com
API_BASE_URL=https://api.dottiwork.com
CORS_ALLOWED_ORIGINS=https://dotti.work,https://dottiwork.com,http://localhost:3000

SESSION_COOKIE_NAME=dotti_session
SESSION_COOKIE_DOMAIN=.dottiwork.com
SESSION_COOKIE_SECURE=true
SESSION_TOKEN_TTL_SECONDS=2592000

DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=

OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=https://api.dottiwork.com/auth/github/callback
OAUTH_GITHUB_SCOPES=read:user,user:email
OAUTH_GITHUB_API_VERSION=2022-11-28
OAUTH_GITHUB_USER_AGENT=dotti-work-api
OAUTH_GITHUB_CONNECT_TIMEOUT=5
OAUTH_GITHUB_TIMEOUT=15

REPOSITORY_CACHE_TTL_SECONDS=21600
ISSUES_CACHE_TTL_SECONDS=3600
MATCH_CACHE_TTL_SECONDS=3600
MATCH_REFRESH_COOLDOWN_SECONDS=60

DOCS_USER=
DOCS_PASSWORD=

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=DottiWork

SENTRY_DSN=
