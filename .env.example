# Application
APP_ENV=local
APP_SECRET=
APP_ENCRYPTION_KEY=

# Public URLs
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost/dottiwork_api/api
PUBLIC_PROFILE_BASE_URL=http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost/dottiwork_api/api
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Session and rate limiting
SESSION_COOKIE_NAME=dotti_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_TOKEN_TTL_SECONDS=2592000
RATE_LIMIT_ENABLED=true

# Database
DB_HOST=127.0.0.1
DB_NAME=dottiwork_db
DB_USER=root
DB_PASSWORD=

# GitHub OAuth App
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=http://localhost/dottiwork_api/api/auth/github/callback
OAUTH_GITHUB_SCOPES=read:user,user:email
OAUTH_GITHUB_API_VERSION=2022-11-28
OAUTH_GITHUB_USER_AGENT=dotti-work-api
OAUTH_GITHUB_CONNECT_TIMEOUT=5
OAUTH_GITHUB_TIMEOUT=15

# GitHub cache and matching
REPOSITORY_CACHE_TTL_SECONDS=21600
ISSUES_CACHE_TTL_SECONDS=3600
MATCH_CACHE_TTL_SECONDS=3600
MATCH_REFRESH_COOLDOWN_SECONDS=60
MATCH_SEARCH_PER_QUERY=15
MATCH_CANDIDATE_LIMIT=30
MATCH_RESULT_LIMIT=30
MATCH_ISSUES_PER_REPOSITORY=20

# Swagger UI Basic Auth
DOCS_USER=docs
DOCS_PASSWORD=docs

# Transactional email (optional for local development)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=DottiWork

# Observability
SENTRY_DSN=
SENTRY_TEST_ENABLED=false
